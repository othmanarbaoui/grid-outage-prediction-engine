# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ─────────────────────────────────────
.env
*.env
!.env.example

# ── ML artifacts (large binary files — use DVC or LFS instead)
app/artifacts/*.keras
app/artifacts/*.joblib
app/artifacts/*.pkl
app/artifacts/*.h5
# Allow the placeholder README
!app/artifacts/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs / outputs ────────────────────────────────────────────
*.log
*.png
*.csv
*.npz

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
